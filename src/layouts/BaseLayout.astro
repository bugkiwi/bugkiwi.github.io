---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import PlayerWidget from '../components/PlayerWidget.astro';
import PlayerEngine from '../components/PlayerEngine.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'gkiwi';
const fullTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const siteUrl = Astro.site ?? 'https://bugkiwi.github.io';
const avatarUrl = new URL('/images/avatar.png', siteUrl).href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="gkiwi" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16.png" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <meta property="og:image" content={avatarUrl} />
    <meta name="twitter:image" content={avatarUrl} />
    <title>{fullTitle}</title>

    <!-- 客户端路由：文章间软切换，让全局播放器持续播放 -->
    <ClientRouter />

    <!-- 西部木刻招牌体 Rye + 打字机体 Special Elite -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rye&family=Special+Elite&display=swap"
      rel="stylesheet"
    />

    <!-- 防止暗色模式闪烁：在渲染前先设定主题 -->
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const dark =
        stored === 'dark' ||
        (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.dataset.theme = dark ? 'dark' : 'light';
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="gkiwi 首页">
        <img src="/images/logo.png" alt="" width="38" height="38" aria-hidden="true" />
        <span class="site-title">gkiwi</span>
      </a>

      <nav class="site-nav">
        <a href="/">首页</a>
      </nav>

      <PlayerWidget />

      <button
        class="theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="切换明暗主题"
        title="切换明暗主题"
      >
        <span data-light>☀️</span>
        <span data-dark hidden>🌙</span>
      </button>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <img
        class="site-avatar"
        src="/images/avatar.png"
        alt="gkiwi"
        width="32"
        height="32"
      />
      <p>
        <span class="horseshoe">✦</span> © {new Date().getFullYear()} gkiwi · Howdy
        partner, built with Astro <span class="horseshoe">✦</span>
      </p>
    </footer>

    <!-- 持久化音频引擎（不可见，放 body 根部保证跨导航不中断、不错位） -->
    <PlayerEngine />

    <script is:inline>
      function applyStoredTheme() {
        const stored = localStorage.getItem('theme');
        const dark =
          stored === 'dark' ||
          (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
      }

      function syncThemeToggleIcons() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const sun = btn.querySelector('[data-light]');
        const moon = btn.querySelector('[data-dark]');
        const dark = document.documentElement.dataset.theme === 'dark';
        sun.hidden = dark;
        moon.hidden = !dark;
      }

      function bindThemeToggle() {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.dataset.theme === 'dark';
          const next = isDark ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
          syncThemeToggleIcons();
        });
      }

      // 软导航会替换 html 属性，需在每次换页后从 localStorage 恢复主题。
      document.addEventListener('astro:page-load', () => {
        applyStoredTheme();
        syncThemeToggleIcons();
        bindThemeToggle();
      });
    </script>
  </body>
</html>
